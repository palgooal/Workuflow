# ==========================================
# .env.production.example
# انسخ هذا الملف إلى .env على السيرفر
# وعدّل القيم حسب إعدادات استضافتك
# ==========================================

APP_NAME=darahum
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://workuflow.yourdomain.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ───────────────────────────────
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ──────────────────────────────
# احصل على هذه القيم من cPanel → MySQL Databases
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpanel_username_workuflow
DB_USERNAME=cpanel_username_dbuser
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# ─── Session ───────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com
SESSION_SECURE_COOKIE=true

# ─── Queue ─────────────────────────────────
# database مناسب للـ Shared Hosting (لا يحتاج Redis)
QUEUE_CONNECTION=database

# ─── Cache ─────────────────────────────────
CACHE_STORE=database

# ─── Broadcast ─────────────────────────────
BROADCAST_CONNECTION=log

# ─── Filesystem ────────────────────────────
FILESYSTEM_DISK=local

# ─── Mail ──────────────────────────────────
# استخدم إعدادات SMTP من cPanel → Email Accounts
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=mail.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=YOUR_EMAIL_PASSWORD_HERE
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="Workuflow"

# ─── Billing ────────────────────────────────
BILLING_PROVIDER=
BILLING_CURRENCY=SAR
BILLING_PRICE_PRO=99
BILLING_PRICE_BUSINESS=299
PAYMENT_KEY=
PAYMENT_SECRET=
PAYMENT_WEBHOOK_SECRET=
